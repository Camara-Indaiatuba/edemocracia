+  function revealAmendment(amendmentEl) {
+    const scrollContainer = amendmentEl.closest('.content__amendments');
+    if (!scrollContainer) {
+      amendmentEl.scrollIntoView({
+        block: 'nearest',
+        inline: 'nearest',
+        behavior: 'smooth',
+      });
+      return;
+    }
+
+    window.requestAnimationFrame(() => {
+      const containerRect = scrollContainer.getBoundingClientRect();
+      const amendmentRect = amendmentEl.getBoundingClientRect();
+      const targetTop = scrollContainer.scrollTop + amendmentRect.top - containerRect.top - 16;
+
+      scrollContainer.scrollTo({
+        top: Math.max(0, targetTop),
+        behavior: 'smooth',
+      });
+    });
+  }
+
   function toggle(form) {
     const wrapperEl = document.querySelector('[data-form-visible]');
     wrapperEl.dataset.formVisible = form;
