+def _save_count_fields(instance, **counts):
+    changed_fields = []
+    for field, value in counts.items():
+        if getattr(instance, field) != value:
+            setattr(instance, field, value)
+            changed_fields.append(field)
+
+    if changed_fields:
+        instance.save(update_fields=changed_fields)
+
+
+def _recalculate_bill_amendments_count(bill):
+    total = 0
+    for segment in bill.segments.all():
+        total += segment.additive_amendments.count()
+        total += segment.modifier_amendments.count()
+        total += segment.supress_amendments.count()
+
+    _save_count_fields(bill, amendments_count=total)
+
+
+def _recalculate_segment_amendments_count(segment):
+    additive_count = segment.additive_amendments.count()
+    modifier_count = segment.modifier_amendments.count()
+    supress_count = segment.supress_amendments.count()
+    total = additive_count + modifier_count + supress_count
+
+    _save_count_fields(
+        segment,
+        amendments_count=total,
+        additive_amendments_count=additive_count,
+        modifier_amendments_count=modifier_count,
+        supress_amendments_count=supress_count,
+    )
+    _recalculate_bill_amendments_count(segment.bill)
+
+
+def update_additive_amendment_count(sender, instance, **kwargs):
+    _recalculate_segment_amendments_count(instance.reference)
+
+
+def update_modifier_amendment_count(sender, instance, **kwargs):
+    _recalculate_segment_amendments_count(instance.replaced)
+
+
+def update_supress_amendment_count(sender, instance, **kwargs):
+    _recalculate_segment_amendments_count(instance.supressed)
