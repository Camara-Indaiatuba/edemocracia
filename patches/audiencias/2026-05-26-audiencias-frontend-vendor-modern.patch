@@ -0,0 +1,55 @@
+const fs = require('fs');
+const path = require('path');
+
+const root = path.resolve(__dirname, '..');
+
+function copyRecursive(source, target) {
+  const stat = fs.statSync(source);
+
+  if (stat.isDirectory()) {
+    fs.mkdirSync(target, { recursive: true });
+
+    for (const entry of fs.readdirSync(source)) {
+      copyRecursive(path.join(source, entry), path.join(target, entry));
+    }
+
+    return;
+  }
+
+  fs.mkdirSync(path.dirname(target), { recursive: true });
+  fs.copyFileSync(source, target);
+}
+
+function fromRoot(...parts) {
+  return path.join(root, ...parts);
+}
+
+const targets = [
+  'static/vendor/jquery-ui',
+  'static/vendor/mixitup',
+  'static/bower_components/jquery-ui',
+  'static/bower_components/mixitup',
+  'public/jquery-ui',
+  'public/mixitup',
+  'public/bower_components/jquery-ui',
+  'public/bower_components/mixitup',
+];
+
+for (const target of targets) {
+  fs.rmSync(fromRoot(target), { recursive: true, force: true });
+}
+
+copyRecursive(
+  fromRoot('node_modules/jquery-ui/dist/jquery-ui.min.js'),
+  fromRoot('static/vendor/jquery-ui/jquery-ui.min.js'),
+);
+
+copyRecursive(
+  fromRoot('node_modules/jquery-ui/dist/themes/flick'),
+  fromRoot('static/vendor/jquery-ui/themes/flick'),
+);
+
+copyRecursive(
+  fromRoot('node_modules/mixitup/dist/mixitup.min.js'),
+  fromRoot('static/vendor/mixitup/mixitup.min.js'),
+);
