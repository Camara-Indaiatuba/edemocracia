+(function(window, $) {
+  'use strict';
+
+  var DATA_KEY = 'audiencias.mixitup3';
+
+  function getMixer(element, options) {
+    var mixer = $.data(element, DATA_KEY);
+
+    if (mixer) {
+      return mixer;
+    }
+
+    if (typeof window.mixitup !== 'function') {
+      throw new Error('MixItUp 3 is required before loading jquery.mixitup-v2-adapter.js');
+    }
+
+    mixer = window.mixitup(element, {
+      selectors: (options && options.selectors) || { target: '.mix' },
+    });
+
+    $.data(element, DATA_KEY, mixer);
+
+    return mixer;
+  }
+
+  $.fn.mixItUp = function(action, value) {
+    if (typeof action === 'string') {
+      return this.each(function() {
+        var mixer = getMixer(this);
+
+        if (action === 'sort') {
+          mixer.forceRefresh();
+          mixer.sort(value || 'default:asc');
+        } else if (action === 'destroy') {
+          mixer.destroy();
+          $.removeData(this, DATA_KEY);
+        }
+      });
+    }
+
+    return this.each(function() {
+      getMixer(this, action || {});
+    });
+  };
+})(window, window.jQuery);
