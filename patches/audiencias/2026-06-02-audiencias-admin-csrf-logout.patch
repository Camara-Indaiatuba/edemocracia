diff --git a/static/js/helpers/cookies.js b/static/js/helpers/cookies.js
--- a/static/js/helpers/cookies.js
+++ b/static/js/helpers/cookies.js
@@
 function getCookie(name) {
-    let cookieValue = null;
+    const names = name === 'csrftoken' ? ['audiencias_csrftoken', 'csrftoken'] : [name];
+
     if (document.cookie && document.cookie !== '') {
         var cookies = document.cookie.split(';');
-        for (var i = 0; i < cookies.length; i++) {
-            var cookie = cookies[i].trim();
-            // Does this cookie string begin with the name we want?
-            if (cookie.substring(0, name.length + 1) === (name + '=')) {
-                cookieValue = decodeURIComponent(cookie.substring(name.length + 1));
-                break;
+        for (var n = 0; n < names.length; n++) {
+            var cookieName = names[n];
+            for (var i = 0; i < cookies.length; i++) {
+                var cookie = cookies[i].trim();
+                if (cookie.substring(0, cookieName.length + 1) === (cookieName + '=')) {
+                    return decodeURIComponent(cookie.substring(cookieName.length + 1));
+                }
             }
         }
     }
-    return cookieValue;
+
+    return null;
 }
 
 export { getCookie }
