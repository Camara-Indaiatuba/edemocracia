diff --git a/scripts/sass-compiler.js b/scripts/sass-compiler.js
new file mode 100644
index 0000000..0a1753e
--- /dev/null
+++ b/scripts/sass-compiler.js
@@ -0,0 +1,79 @@
+const fs = require('fs');
+const path = require('path');
+const sass = require('sass');
+
+function takeValue(args, index) {
+  const current = args[index];
+  if (current.includes('=')) {
+    return [current.split('=').slice(1).join('='), index];
+  }
+  return [args[index + 1], index + 1];
+}
+
+function parseArgs(args) {
+  const options = {
+    loadPaths: [],
+    sourceMap: false,
+    sourceMapIncludeSources: false,
+    sourceMapEmbed: false,
+    style: 'expanded',
+    positional: [],
+  };
+
+  for (let index = 0; index < args.length; index += 1) {
+    const arg = args[index];
+
+    if (arg === '--include-path' || arg.startsWith('--include-path=')) {
+      const [value, nextIndex] = takeValue(args, index);
+      if (value) options.loadPaths.push(value);
+      index = nextIndex;
+    } else if (arg === '--load-path' || arg.startsWith('--load-path=')) {
+      const [value, nextIndex] = takeValue(args, index);
+      if (value) options.loadPaths.push(value);
+      index = nextIndex;
+    } else if (arg === '--output-style' || arg.startsWith('--output-style=')) {
+      const [value, nextIndex] = takeValue(args, index);
+      if (value) options.style = value === 'compressed' ? 'compressed' : 'expanded';
+      index = nextIndex;
+    } else if (arg === '--source-map') {
+      options.sourceMap = true;
+    } else if (arg === '--source-map-contents') {
+      options.sourceMapIncludeSources = true;
+    } else if (arg === '--source-map-embed') {
+      options.sourceMapEmbed = true;
+    } else if (!arg.startsWith('-')) {
+      options.positional.push(arg);
+    }
+  }
+
+  if (options.positional.length < 2) {
+    throw new Error('Usage: sass-compiler [legacy SCSS options] <input.scss> <output.css>');
+  }
+
+  options.infile = options.positional[options.positional.length - 2];
+  options.outfile = options.positional[options.positional.length - 1];
+  return options;
+}
+
+function toDataUrl(sourceMap) {
+  return Buffer
+    .from(JSON.stringify(sourceMap), 'utf8')
+    .toString('base64');
+}
+
+const options = parseArgs(process.argv.slice(2));
+const result = sass.compile(options.infile, {
+  loadPaths: options.loadPaths,
+  sourceMap: options.sourceMap,
+  sourceMapIncludeSources: options.sourceMapIncludeSources,
+  style: options.style,
+});
+
+fs.mkdirSync(path.dirname(options.outfile), { recursive: true });
+
+let css = result.css;
+if (options.sourceMap && options.sourceMapEmbed && result.sourceMap) {
+  css += `\n/*# sourceMappingURL=data:application/json;base64,${toDataUrl(result.sourceMap)} */\n`;
+}
+
+fs.writeFileSync(options.outfile, css);
