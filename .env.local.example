# Local environment template.
# Copy this file to .env and fill real values only in .env.
# The .env file is ignored by Git and must not be published.

# Public URL used in generated links, including account activation emails.
PUBLIC_BIND_ADDRESS=0.0.0.0
PUBLIC_HTTP_PORT=8000
SITE_URL=http://192.168.193.110:8000
SITE_DOMAIN=192.168.193.110:8000
ALLOWED_HOSTS=192.168.193.110,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://192.168.193.110:8000,http://localhost:8000,http://127.0.0.1:8000,http://nginx

# Container images. For local development, keep these values aligned with images already built or available.
IMAGE_REGISTRY=ghcr.io/camara-indaiatuba
IMAGE_TAG=1.0.0-rc1

# Security. For public HTTPS access, use DEBUG=False and secure cookies.
EDEMOCRACIA_DEBUG=True
POSTGRES_PASSWORD=change-me-generate-a-long-random-value
EDEMOCRACIA_SECRET_KEY=change-me-generate-a-long-random-value
WIKILEGIS_SECRET_KEY=change-me-generate-a-long-random-value
AUDIENCIAS_SECRET_KEY=change-me-generate-a-long-random-value
DISCOURSE_SSO_SECRET=change-me-generate-a-long-random-value
INTERNAL_API_KEY=change-me-generate-a-long-random-value
WIKILEGIS_API_KEY=change-me-generate-a-long-random-value
AUDIENCIAS_API_KEY=change-me-generate-a-long-random-value
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# Portal identity.
SITE_NAME="Camara Municipal"
SITE_LOGO=/static/img/brasao-camara.svg
SITE_LOGO_TEXT_LINE="Camara Municipal"
SITE_LOGO_TEXT_CITY="Nome da Cidade"
WIKILEGIS_SITE_NAME=Wikilegis
AUDIENCIAS_SITE_NAME=Democracia

# Initial administrator. Change before exposing the site.
ADMIN_EMAIL=admin@example.org
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-generate-a-long-random-value

# SMTP for account activation and notifications.
# Keep EMAIL_BACKEND as SMTP when testing real email.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.org
EMAIL_PORT=587
EMAIL_HOST_USER=no-reply@example.org
EMAIL_HOST_PASSWORD=change-me
# For port 587 usually use TLS=True and SSL=False.
# For port 465 usually use TLS=False and SSL=True.
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL="e-Democracia <no-reply@example.org>"

# Social login.
SOCIAL_AUTH_REDIRECT_IS_HTTPS=False
SOCIAL_AUTH_GOOGLE_OAUTH2_KEY=
SOCIAL_AUTH_GOOGLE_OAUTH2_SECRET=
GOOGLE_LOGIN_ENABLED=False
SOCIAL_AUTH_FACEBOOK_KEY=
SOCIAL_AUTH_FACEBOOK_SECRET=
